{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "OTEL_EXPORTER_OTLP_HEADERS": "Authorization=Bearer ${THOUGHTBOX_API_KEY}"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session_start.sh\" --load-context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool_use.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/ulysses_enforcer.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/ulysses_state_writer.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__thoughtbox-cloud-run__thoughtbox_execute",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/thoughtbox_session_tracker.sh\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/post_compact_context.sh\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent_start_inject.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/stop_landing.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.sh\" &"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/task_completed_gate.sh\"",
            "statusMessage": "Checking test gate..."
          },
          {
            "type": "agent",
            "prompt": "You are the Verification Judge. A task is being marked complete. Validate it independently:\n\n1. Run `git diff --stat` to see recent changes\n2. Check if tests pass for changed files (use `npx vitest run --reporter=verbose` if vitest is configured)\n3. Run `tsc --noEmit` if TypeScript files were changed\n4. Read the task description to understand acceptance criteria\n5. Verify the implementation matches the criteria\n\nYou MUST use deterministic checks (tests, tsc) as first pass. Only use judgment for criteria that cannot be automated.\n\nIf validation fails, respond {\"ok\": false, \"reason\": \"<specific failures with file:line references>\"}.\nIf the SPECIFICATION is the problem (not the implementation), say so explicitly in the reason.\nIf validation passes, respond {\"ok\": true}.",
            "model": "sonnet",
            "timeout": 120,
            "statusMessage": "Verification Judge reviewing..."
          }
        ]
      }
    ]
  }
}
