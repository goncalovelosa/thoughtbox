{
  "$comment": "Hand-curated ground truth for dependency graph validation. Derived from domain knowledge of Gmail, Google Drive, Google Calendar, Google Contacts, and GitHub APIs. Tool slugs are best-guesses based on Composio naming conventions — actual slugs from the API may differ slightly.",

  "entityTypes": [
    { "id": "gmail.thread.id",             "description": "Gmail thread identifier",                    "userProvidable": false },
    { "id": "gmail.message.id",            "description": "Gmail message identifier",                   "userProvidable": false },
    { "id": "gmail.label.id",              "description": "Gmail label identifier",                     "userProvidable": false },
    { "id": "google.drive.file.id",        "description": "Google Drive file identifier",               "userProvidable": false },
    { "id": "google.drive.folder.id",      "description": "Google Drive folder identifier",             "userProvidable": false },
    { "id": "google.calendar.event.id",    "description": "Google Calendar event identifier",           "userProvidable": false },
    { "id": "google.contact.id",           "description": "Google Contact identifier",                  "userProvidable": false },
    { "id": "github.issue.number",         "description": "GitHub issue number within a repo",          "userProvidable": false },
    { "id": "github.pull.number",          "description": "GitHub pull request number within a repo",   "userProvidable": false },
    { "id": "github.commit.sha",           "description": "Git commit SHA",                             "userProvidable": false },
    { "id": "github.repo.owner",           "description": "GitHub repository owner (org or user)",      "userProvidable": true  },
    { "id": "github.repo.name",            "description": "GitHub repository name",                     "userProvidable": true  },
    { "id": "email.address",               "description": "Email address (recipient, sender, attendee)","userProvidable": true  },
    { "id": "person.name",                 "description": "Human name for contact lookup",              "userProvidable": true  },
    { "id": "search.query",                "description": "Free-text search string",                    "userProvidable": true  },
    { "id": "email.subject",               "description": "Email subject line",                         "userProvidable": true  },
    { "id": "email.body",                  "description": "Email body content",                         "userProvidable": true  },
    { "id": "github.issue.title",          "description": "Issue title text",                           "userProvidable": true  },
    { "id": "github.issue.body",           "description": "Issue body text",                            "userProvidable": true  },
    { "id": "google.drive.file.name",      "description": "File or document name",                      "userProvidable": true  },
    { "id": "event.title",                 "description": "Calendar event title",                       "userProvidable": true  },
    { "id": "comment.body",                "description": "Comment or reply body text",                 "userProvidable": true  }
  ],

  "tools": [
    {
      "slug": "GMAIL_LIST_THREADS",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "search.query", "required": false }
      ],
      "produces": ["gmail.thread.id"]
    },
    {
      "slug": "GMAIL_GET_THREAD",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "gmail.thread.id", "required": true }
      ],
      "produces": ["gmail.thread.id", "gmail.message.id"]
    },
    {
      "slug": "GMAIL_REPLY_TO_THREAD",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "gmail.thread.id", "required": true },
        { "resourceType": "email.body",      "required": true }
      ],
      "produces": ["gmail.message.id"]
    },
    {
      "slug": "GMAIL_SEND_EMAIL",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "email.address", "required": true },
        { "resourceType": "email.subject", "required": true },
        { "resourceType": "email.body",    "required": true }
      ],
      "produces": ["gmail.thread.id", "gmail.message.id"]
    },
    {
      "slug": "GMAIL_SEARCH_THREADS",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "search.query", "required": true }
      ],
      "produces": ["gmail.thread.id"]
    },
    {
      "slug": "GMAIL_DELETE_THREAD",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "gmail.thread.id", "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GMAIL_TRASH_EMAIL",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "gmail.message.id", "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GMAIL_CREATE_LABEL",
      "toolkit": "googlesuper",
      "requires": [],
      "produces": ["gmail.label.id"]
    },
    {
      "slug": "GMAIL_ADD_LABEL_TO_EMAIL",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "gmail.message.id", "required": true },
        { "resourceType": "gmail.label.id",   "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GOOGLE_CONTACTS_FIND_CONTACT",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "person.name",  "required": false },
        { "resourceType": "search.query", "required": false }
      ],
      "produces": ["email.address", "person.name", "google.contact.id"]
    },
    {
      "slug": "GOOGLE_CONTACTS_GET_CONTACT",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.contact.id", "required": true }
      ],
      "produces": ["email.address", "person.name"]
    },
    {
      "slug": "GOOGLEDRIVE_LIST_FILES",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "search.query", "required": false }
      ],
      "produces": ["google.drive.file.id", "google.drive.file.name"]
    },
    {
      "slug": "GOOGLEDRIVE_GET_FILE",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.drive.file.id", "required": true }
      ],
      "produces": ["google.drive.file.id", "google.drive.file.name"]
    },
    {
      "slug": "GOOGLEDRIVE_DELETE_FILE",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.drive.file.id", "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GOOGLEDRIVE_MOVE_FILE",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.drive.file.id",   "required": true },
        { "resourceType": "google.drive.folder.id",  "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GOOGLEDRIVE_DOWNLOAD_FILE",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.drive.file.id", "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GOOGLEDRIVE_SEARCH_FILES",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "search.query", "required": true }
      ],
      "produces": ["google.drive.file.id"]
    },
    {
      "slug": "GOOGLECALENDAR_LIST_EVENTS",
      "toolkit": "googlesuper",
      "requires": [],
      "produces": ["google.calendar.event.id"]
    },
    {
      "slug": "GOOGLECALENDAR_CREATE_EVENT",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "event.title",    "required": true },
        { "resourceType": "email.address",  "required": false }
      ],
      "produces": ["google.calendar.event.id"]
    },
    {
      "slug": "GOOGLECALENDAR_UPDATE_EVENT",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.calendar.event.id", "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GOOGLECALENDAR_DELETE_EVENT",
      "toolkit": "googlesuper",
      "requires": [
        { "resourceType": "google.calendar.event.id", "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GITHUB_LIST_REPOS",
      "toolkit": "github",
      "requires": [],
      "produces": ["github.repo.owner", "github.repo.name"]
    },
    {
      "slug": "GITHUB_GET_REPOSITORY",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner", "required": true },
        { "resourceType": "github.repo.name",  "required": true }
      ],
      "produces": ["github.repo.owner", "github.repo.name"]
    },
    {
      "slug": "GITHUB_LIST_ISSUES",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner", "required": true },
        { "resourceType": "github.repo.name",  "required": true }
      ],
      "produces": ["github.issue.number"]
    },
    {
      "slug": "GITHUB_GET_ISSUE",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner",  "required": true },
        { "resourceType": "github.repo.name",   "required": true },
        { "resourceType": "github.issue.number", "required": true }
      ],
      "produces": ["github.issue.number"]
    },
    {
      "slug": "GITHUB_CREATE_ISSUE",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner",  "required": true },
        { "resourceType": "github.repo.name",   "required": true },
        { "resourceType": "github.issue.title",  "required": true },
        { "resourceType": "github.issue.body",   "required": false }
      ],
      "produces": ["github.issue.number"]
    },
    {
      "slug": "GITHUB_ADD_LABELS_TO_AN_ISSUE",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner",   "required": true },
        { "resourceType": "github.repo.name",    "required": true },
        { "resourceType": "github.issue.number",  "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GITHUB_CREATE_COMMENT_ON_ISSUE",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner",   "required": true },
        { "resourceType": "github.repo.name",    "required": true },
        { "resourceType": "github.issue.number",  "required": true },
        { "resourceType": "comment.body",         "required": true }
      ],
      "produces": []
    },
    {
      "slug": "GITHUB_LIST_PULL_REQUESTS",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner", "required": true },
        { "resourceType": "github.repo.name",  "required": true }
      ],
      "produces": ["github.pull.number"]
    },
    {
      "slug": "GITHUB_GET_PULL_REQUEST",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner", "required": true },
        { "resourceType": "github.repo.name",  "required": true },
        { "resourceType": "github.pull.number", "required": true }
      ],
      "produces": ["github.pull.number", "github.commit.sha"]
    },
    {
      "slug": "GITHUB_MERGE_PULL_REQUEST",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner", "required": true },
        { "resourceType": "github.repo.name",  "required": true },
        { "resourceType": "github.pull.number", "required": true }
      ],
      "produces": ["github.commit.sha"]
    },
    {
      "slug": "GITHUB_LIST_COMMITS",
      "toolkit": "github",
      "requires": [
        { "resourceType": "github.repo.owner", "required": true },
        { "resourceType": "github.repo.name",  "required": true }
      ],
      "produces": ["github.commit.sha"]
    }
  ],

  "expectedEdges": {
    "$comment": "Tiered edge expectations. 'must' = from readme examples, failure is a bug. 'should' = from domain knowledge, absence is a gap. 'may' = plausible cross-service flows, absence is acceptable.",

    "must": [
      { "kind": "produces", "toolSlug": "GMAIL_LIST_THREADS",              "resourceType": "gmail.thread.id",  "description": "LIST_THREADS returns thread IDs (readme example 1)" },
      { "kind": "requires", "toolSlug": "GMAIL_REPLY_TO_THREAD",           "resourceType": "gmail.thread.id",  "description": "REPLY_TO_THREAD needs a thread ID (readme example 1)" },
      { "kind": "produces", "toolSlug": "GOOGLE_CONTACTS_FIND_CONTACT",    "resourceType": "email.address",    "description": "Contact search returns email addresses (readme example 2)" },
      { "kind": "requires", "toolSlug": "GMAIL_SEND_EMAIL",                "resourceType": "email.address",    "description": "SEND_EMAIL needs a recipient address (readme example 2)" },
      { "kind": "requires", "toolSlug": "GOOGLE_CONTACTS_FIND_CONTACT",    "resourceType": "person.name",      "description": "Contact search takes a person name (readme example 2, user input)" }
    ],

    "should": [
      { "kind": "produces", "toolSlug": "GITHUB_LIST_ISSUES",              "resourceType": "github.issue.number", "description": "LIST_ISSUES returns issue numbers" },
      { "kind": "requires", "toolSlug": "GITHUB_ADD_LABELS_TO_AN_ISSUE",   "resourceType": "github.issue.number", "description": "ADD_LABELS needs an issue number" },
      { "kind": "produces", "toolSlug": "GITHUB_LIST_REPOS",               "resourceType": "github.repo.owner",   "description": "LIST_REPOS returns repo owner" },
      { "kind": "produces", "toolSlug": "GITHUB_LIST_REPOS",               "resourceType": "github.repo.name",    "description": "LIST_REPOS returns repo name" },
      { "kind": "requires", "toolSlug": "GITHUB_LIST_ISSUES",              "resourceType": "github.repo.owner",   "description": "LIST_ISSUES scoped to repo owner" },
      { "kind": "requires", "toolSlug": "GITHUB_LIST_ISSUES",              "resourceType": "github.repo.name",    "description": "LIST_ISSUES scoped to repo name" },
      { "kind": "produces", "toolSlug": "GMAIL_SEND_EMAIL",                "resourceType": "gmail.thread.id",     "description": "SEND_EMAIL creates a new thread" },
      { "kind": "produces", "toolSlug": "GOOGLEDRIVE_LIST_FILES",          "resourceType": "google.drive.file.id","description": "LIST_FILES returns file IDs" },
      { "kind": "requires", "toolSlug": "GOOGLEDRIVE_DELETE_FILE",         "resourceType": "google.drive.file.id","description": "DELETE_FILE needs a file ID" },
      { "kind": "produces", "toolSlug": "GOOGLECALENDAR_LIST_EVENTS",      "resourceType": "google.calendar.event.id", "description": "LIST_EVENTS returns event IDs" },
      { "kind": "requires", "toolSlug": "GOOGLECALENDAR_UPDATE_EVENT",     "resourceType": "google.calendar.event.id", "description": "UPDATE_EVENT needs an event ID" },
      { "kind": "produces", "toolSlug": "GITHUB_LIST_PULL_REQUESTS",       "resourceType": "github.pull.number",  "description": "LIST_PRS returns PR numbers" },
      { "kind": "requires", "toolSlug": "GITHUB_MERGE_PULL_REQUEST",       "resourceType": "github.pull.number",  "description": "MERGE_PR needs a PR number" },
      { "kind": "produces", "toolSlug": "GMAIL_REPLY_TO_THREAD",           "resourceType": "gmail.message.id",    "description": "REPLY produces a message ID" },
      { "kind": "requires", "toolSlug": "GMAIL_TRASH_EMAIL",               "resourceType": "gmail.message.id",    "description": "TRASH needs a message ID" }
    ],

    "may": [
      { "kind": "produces", "toolSlug": "GOOGLECALENDAR_CREATE_EVENT",     "resourceType": "google.calendar.event.id", "description": "CREATE_EVENT returns new event ID" },
      { "kind": "requires", "toolSlug": "GOOGLECALENDAR_CREATE_EVENT",     "resourceType": "email.address",            "description": "CREATE_EVENT may accept attendee emails" },
      { "kind": "produces", "toolSlug": "GITHUB_GET_PULL_REQUEST",         "resourceType": "github.commit.sha",        "description": "GET_PR may expose head commit SHA" },
      { "kind": "produces", "toolSlug": "GITHUB_MERGE_PULL_REQUEST",       "resourceType": "github.commit.sha",        "description": "MERGE produces a merge commit SHA" },
      { "kind": "produces", "toolSlug": "GITHUB_LIST_COMMITS",             "resourceType": "github.commit.sha",        "description": "LIST_COMMITS returns commit SHAs" }
    ]
  },

  "expectedReachability": {
    "$comment": "Expected minimum layer depth from user-providable inputs. Layer 0 = directly invocable with user inputs only. Layer 1 = needs one tool call first. Layer 2+ = needs chained calls.",
    "layer0": [
      "GMAIL_LIST_THREADS", "GMAIL_SEARCH_THREADS", "GMAIL_SEND_EMAIL", "GMAIL_CREATE_LABEL",
      "GOOGLE_CONTACTS_FIND_CONTACT",
      "GOOGLEDRIVE_LIST_FILES", "GOOGLEDRIVE_SEARCH_FILES",
      "GOOGLECALENDAR_LIST_EVENTS", "GOOGLECALENDAR_CREATE_EVENT",
      "GITHUB_LIST_REPOS", "GITHUB_GET_REPOSITORY", "GITHUB_LIST_ISSUES",
      "GITHUB_CREATE_ISSUE", "GITHUB_LIST_PULL_REQUESTS", "GITHUB_LIST_COMMITS"
    ],
    "layer1": [
      "GMAIL_GET_THREAD", "GMAIL_REPLY_TO_THREAD", "GMAIL_DELETE_THREAD",
      "GOOGLE_CONTACTS_GET_CONTACT",
      "GOOGLEDRIVE_GET_FILE", "GOOGLEDRIVE_DELETE_FILE", "GOOGLEDRIVE_DOWNLOAD_FILE",
      "GOOGLECALENDAR_UPDATE_EVENT", "GOOGLECALENDAR_DELETE_EVENT",
      "GITHUB_GET_ISSUE", "GITHUB_ADD_LABELS_TO_AN_ISSUE", "GITHUB_CREATE_COMMENT_ON_ISSUE",
      "GITHUB_GET_PULL_REQUEST", "GITHUB_MERGE_PULL_REQUEST"
    ],
    "layer2": [
      "GMAIL_TRASH_EMAIL", "GMAIL_ADD_LABEL_TO_EMAIL",
      "GOOGLEDRIVE_MOVE_FILE"
    ]
  }
}
