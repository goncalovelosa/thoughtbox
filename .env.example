# Copy to .env.local for local development
# These are NOT committed. See .specs/deployment/cloud-run-service-config.md

# ── Supabase (WS-02 / ADR-DATA-01) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=https://your-site.com

# ── Redis (WS-01 / ADR-GCP-01) ───────────────────────────────────────────────
# Used for Next.js ISR cache handler in multi-instance Cloud Run deployment
REDIS_URL=redis://localhost:6379

# ── Thoughtbox MCP ──────────────────────────────────────────────────────────
# Static API key set on the MCP Cloud Run service (AUTH-02)
THOUGHTBOX_API_KEY=your-api-key

# ── App ───────────────────────────────────────────────────────────────────────
# Set to production when deploying to Cloud Run
NODE_ENV=development

# Cloud Run injects PORT automatically; override locally if needed
# PORT=8080
