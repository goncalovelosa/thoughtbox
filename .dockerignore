# =============================================================================
# Docker Build Exclusions
# =============================================================================
# These files and directories are excluded from the Docker build context
# to reduce image size and build time.

# =============================================================================
# Build Artifacts & Dependencies
# =============================================================================
node_modules
dist
.smithery
*.log
npm-debug.log

# =============================================================================
# Version Control & CI
# =============================================================================
.git
.github
.gitignore

# =============================================================================
# IDE & Editor Configuration
# =============================================================================
.vscode
.idea
.cursor
.DS_Store

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
cc_mcp_config.json
.mcp.json
.mcp.github.json

# =============================================================================
# Reference Projects (NOT part of Thoughtbox)
# =============================================================================
# Srcbook - reference implementation, not needed in build
srcbook/
kastalien-srcbook/

# =============================================================================
# Development & Documentation (local only)
# =============================================================================
# Documentation directories
docs/
specs/
.specs/
local-docs/
smithery-docs/
mcp-specs/
ai_docs/
dgm-specs/
plans/
self-improvement/
traces/
resources/


