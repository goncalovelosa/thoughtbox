{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error"
  },
  "plugins": ["unicorn"],
  "rules": {
    "require-await": "allow",
    "no-inline-comments": "allow",
    "no-useless-escape": "allow",
    "no-negated-condition": "allow",
    "max-depth": "allow",
    "radix": "allow",
    "no-else-return": "allow",
    "no-unused-vars": "allow",
    "no-shadow": "allow",
    "eqeqeq": "allow",
    "no-case-declarations": "allow",
    "max-lines-per-function": "allow",
    "max-lines": "allow",
    "max-classes-per-file": "allow",
    "no-dupe-else-if": "allow",
    "no-promise-executor-return": "allow",
    "no-warning-comments": "allow",
    "preserve-caught-error": "allow",
    "unicorn/prefer-string-replace-all": "allow",
    "unicorn/no-useless-undefined": "allow",
    "unicorn/no-array-sort": "allow",
    "unicorn/prefer-at": "allow",
    "unicorn/prefer-string-slice": "allow",
    "unicorn/no-array-callback-reference": "allow",
    "unicorn/prefer-type-error": "allow",
    "unicorn/no-useless-switch-case": "allow",
    "unicorn/no-immediate-mutation": "allow",
    "unicorn/consistent-function-scoping": "allow",
    "unicorn/explicit-length-check": "allow",
    "unicorn/no-lonely-if": "allow",
    "unicorn/no-useless-fallback-in-spread": "allow",
    "unicorn/prefer-add-event-listener": "allow",
    "unicorn/prefer-event-target": "allow",
    "unicorn/prefer-top-level-await": "allow",
    "oxc/no-async-endpoint-handlers": "allow"
  },
  "ignorePatterns": ["dist/", "node_modules/", "*.test.ts", "*.spec.ts"]
}
