    "node": ">=22.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "dotenv": "^17.2.3",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "@types/pg": "^8.11.11",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  }
}
